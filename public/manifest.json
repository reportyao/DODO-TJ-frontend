    },
    {
      "src": "/dodo-logo.webp",
      "sizes": "192x192",
      "type": "image/webp",
      "purpose": "maskable"
    },
    {
      "src": "/dodo-logo.webp",
      "sizes": "512x512",
      "type": "image/webp",
